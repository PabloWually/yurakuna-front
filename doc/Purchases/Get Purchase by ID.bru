meta {
  name: Get Purchase by ID
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/purchases/:id
  body: none
  auth: bearer
}

params:path {
  id: 00000000-0000-0000-0000-000000000000
}

auth:bearer {
  token: {{accessToken}}
}

docs {
  Returns the purchase with full details including provider and all items.
}
